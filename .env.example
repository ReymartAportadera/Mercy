# TrustFile Environment Variables Configuration Example
# Copy this file to '.env' and fill in your actual credentials.

# 1. Firebase Configurations
FIREBASE_DB_URL=https://your-project-id-default-rtdb.firebaseio.com/
# (Optional) Path to your Firebase service account JSON.
# If omitted, it automatically defaults to 'serviceAccountKey.json' in the project root.
# FIREBASE_SERVICE_ACCOUNT=serviceAccountKey.json

# 2. Flask Application Configurations
TRUSTFILE_SECRET_KEY=generate_a_random_secure_hex_key_here
# (Optional) Folder for uploaded files. Defaults to 'uploads' inside the project root.
# UPLOAD_FOLDER=uploads
APP_DEBUG=true

# 3. Third-party Security API keys
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
